#!/bin/sh
echo "🔍 Checking if dependencies need to be updated..."

# Check if package.json or package-lock changed
changed_files="$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD)"

check_run() {
    echo "$changed_files" | grep -q "$1" && eval "$2"
}

# Check if package.json changed
check_run "package.json" "echo '📦 package.json changed, updating dependencies...' && npm install"

# Check if package-lock changed
check_run "package-lock" "echo '🔒 package-lock changed, updating dependencies...' && npm install"

echo "✅ Post-merge checks completed!" 